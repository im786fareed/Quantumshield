# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to git — it contains sensitive credentials.
#
# HOW TO CREATE A KEYSTORE:
# Run this command in your terminal (requires Java / Android Studio installed):
#
#   keytool -genkey -v -keystore quantumshield-release.jks \
#     -alias quantumshield \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -dname "CN=QuantumShield, OU=Security, O=QuantumShield, L=India, S=India, C=IN"
#
# Then place quantumshield-release.jks inside android/ folder (it is gitignored via *.jks)

storeFile=quantumshield-release.jks
storePassword=YOUR_STORE_PASSWORD_HERE
keyAlias=quantumshield
keyPassword=YOUR_KEY_PASSWORD_HERE
